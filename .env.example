# 数据库连接（NeonDB）
# 格式：postgresql://用户名:密码@主机地址/数据库名?sslmode=require
DATABASE_URL="postgresql://neondb_owner:你的密码@ep-withered-bar-a1hm4ybf-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT 密钥（生产环境请重新生成随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-this"

# 服务器端口
PORT=3001
