# 生产环境配置
# 部署前复制为 .env 并修改以下值

# 数据库连接（保持 NeonDB 或切换到生产数据库）
DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"

# JWT 配置（生产环境必须使用强密钥）
JWT_SECRET="change-to-random-32-char-secret-key"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=3001
NODE_ENV=production

# 前端域名（CORS 白名单）
CLIENT_URL="https://your-frontend-domain.com"
